[
  {
    "id": "deploy",
    "execute-command": "/scripts/deploy.sh",
    "command-working-directory": "/",
    "pass-arguments-to-command": [
      {
        "source": "url",
        "name": "app"
      }
    ],
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "{{ getenv "DEPLOY_SECRET" }}",
        "parameter": {
          "source": "header",
          "name": "X-Deploy-Token"
        }
      }
    }
  }
]